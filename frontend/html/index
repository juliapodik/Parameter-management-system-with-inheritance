<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Система параметров | Наследование</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'></text></svg>">
    <link rel="stylesheet" href="../css/style.css">
</head>
<body>
    <div class="container">
        <div class="main-card">
            <div class="header" style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h1 style="margin: 0;">
                        <img src="../images/icon-system.svg" width="36" height="36" style="vertical-align: middle;">
                        Система управления параметрами
                    </h1>
                    <p style="margin: 8px 0 0 0;">Наследование параметров от группы к элементу с возможностью переопределения</p>
                </div>
                <div style="display: flex; gap: 15px;">
                    <img src="../images/logo-rim.svg" width="75" height="75" alt="АО «РиМ»">
                    <img src="../images/logo-nstu.svg" width="90" height="90" alt="НГТУ">
                </div>
            </div>
            
            <div class="two-columns">
                <div class="left-panel">
                    <div class="section">
                        <h3>
                            <img src="../images/icon-folder.svg" width="20" height="20" style="vertical-align: middle;">
                            Группы и элементы
                        </h3>
                        <div id="groupsList" class="items-list">Загрузка...</div>
                        <div class="input-group">
                            <input type="text" id="newGroup" placeholder="Название группы">
                            <button class="add-btn" onclick="createGroup()">Создать</button>
                        </div>
                    </div>
                    
                    <div class="section">
                        <h3>
                            <img src="../images/icon-plus.svg" width="18" height="18" style="vertical-align: middle;">
                            Создать элемент
                        </h3>
                        <select id="groupSelect"></select>
                        <div class="input-group">
                            <input type="text" id="newElement" placeholder="Название элемента">
                            <button class="add-btn" onclick="createElementBtn()">Создать</button>
                        </div>
                    </div>
                </div>
                
                <div class="right-panel">
                    <div class="section">
                        <h3>
                            <img src="../images/icon-edit.svg" width="18" height="18" style="vertical-align: middle;">
                            <span id="title">Редактор параметров</span>
                        </h3>
                        <div id="params"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div id="message" class="message"></div>
    
    <script src="../js/script.js"></script>
</body>
</html>
